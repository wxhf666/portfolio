# ===== AI 问答 Agent =====
# DeepSeek API Key — 用于 AI 问答 Agent
# 获取地址：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ===== 联系表单邮件通知 =====
# QQ 邮箱 SMTP 配置
# SMTP 授权码获取：QQ 邮箱 → 设置 → 账户 → POP3/SMTP 服务 → 生成授权码
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your_qq_email@qq.com
SMTP_PASS=your_smtp_auth_code
NOTIFY_EMAIL=your_qq_email@qq.com
